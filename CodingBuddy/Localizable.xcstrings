    "Agent Doctor guidance expired credential consequence" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Verbindung kann nach einer automatischen Aktualisierung weiter funktionieren, eine erneute Anmeldung verlangen oder fehlschlagen, bis die Anmeldung erneuert wurde."
          }
        }
      }
    },
    "Agent Doctor guidance expired credential explanation" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das zwischengespeicherte OAuth-Zugriffstoken scheint laut gespeichertem Ablaufzeitpunkt abgelaufen zu sein. Ein OAuth-Client kann es eventuell automatisch aktualisieren, aber Agent Doctor kann nicht bestätigen, ob das gelingt."
          }
        }
      }
    },
    "Agent Doctor guidance expired credential relevance" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine MCP-Serververbindung benötigt eine aktuelle OAuth-Anmeldung oder eine erfolgreiche Token-Aktualisierung."
          }
        }
      }
    },
    "Agent Doctor guidance incomplete credential consequence" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Verbindung kann eine erneute Anmeldung verlangen oder fehlschlagen, bis vollständige Zugangsdaten erstellt wurden."
          }
        }
      }
    },
    "Agent Doctor guidance incomplete credential explanation" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein OAuth-Cache-Eintrag ist vorhanden, aber die für eine vollständige Anmeldung benötigte Token-Datei fehlt. Agent Doctor kann nicht erkennen, ob die Anmeldung unterbrochen, abgebrochen oder nie abgeschlossen wurde."
          }
        }
      }
    },
    "Agent Doctor guidance incomplete credential relevance" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der MCP-Client benötigt einen vollständigen OAuth-Cache-Eintrag, bevor er diese Anmeldung wiederverwenden kann."
          }
        }
      }
    },
    "Agent Doctor guidance incomplete credential scan consequence" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Außerhalb der gemeldeten Ergebnisse können weitere abgelaufene, unvollständige oder unsichere Zugangsdaten-Artefakte vorhanden sein."
          }
        }
      }
    },
    "Agent Doctor guidance incomplete credential scan explanation" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agent Doctor hat einen Teil des MCP-Auth-Caches bewusst ausgelassen, weil diese Eingabe nicht innerhalb der Sicherheitsgrenzen geprüft werden konnte."
          }
        }
      }
    },
    "Agent Doctor guidance incomplete credential scan relevance" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur nach einem vollständigen Scan des Zugangsdaten-Caches ist ein leeres oder unauffälliges Ergebnis belastbar."
          }
        }
      }
    },
    "Agent Doctor guidance invalid config file consequence" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einstellungen oder Verbindungen aus dieser Datei können ignoriert werden, bis die JSON-Syntax korrigiert ist."
