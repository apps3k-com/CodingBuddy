{
  "sourceLanguage" : "en",
  "strings" : {
    "%lld variables" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld Variablen"
          }
        }
      }
    },
    "“%@” is already defined." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„%@“ ist bereits definiert."
          }
        }
      }
    },
    "“%@” is already defined in %@ — the last assignment in load order wins." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„%1$@“ ist bereits in %2$@ definiert — es gilt die letzte Zuweisung in der Ladereihenfolge."
          }
        }
      }
    },
    "“%@” is not a valid variable name." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„%@“ ist kein gültiger Variablenname."
          }
        }
      }
    },
    "A backup of the file is written automatically before the change." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vor der Änderung wird automatisch ein Backup der Datei angelegt."
          }
        }
      }
    },
    "A later assignment overrides this value in new terminal sessions." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine spätere Zuweisung überschreibt diesen Wert in neuen Terminal-Sessions."
