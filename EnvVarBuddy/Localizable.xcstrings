    },
    "“%@” is already defined in %@ — the last assignment in load order wins." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„%1$@“ ist bereits in %2$@ definiert — es gilt die letzte Zuweisung in der Ladereihenfolge."
