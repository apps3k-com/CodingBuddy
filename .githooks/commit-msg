#!/bin/sh
# Enforces Conventional Commits — release-please derives versions from these.
# Activate once per clone: ./scripts/setup.sh

MSG_FILE="$1"
FIRST_LINE=$(head -n 1 "$MSG_FILE")

# Merge commits and fixups are exempt.
case "$FIRST_LINE" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *) exit 0 ;;
esac

if ! echo "$FIRST_LINE" | grep -qE '^(feat|fix|docs|chore|ci|refactor|test|perf|build|style|revert)(\([a-z0-9_-]+\))?!?: .+'; then
  echo "✖ Commit message must follow Conventional Commits:" >&2
  echo "    feat: …  fix: …  docs: …  chore: …  (optional scope, '!' for breaking)" >&2
  echo "  Got: $FIRST_LINE" >&2
  exit 1
fi

# Release-please's release commits carry no work item.
case "$FIRST_LINE" in
  chore\(main\):\ release*) exit 0 ;;
esac

# Every commit references the Plane work item(s) it contains or relates to.
if ! grep -qE 'COBUD-[0-9]+' "$MSG_FILE"; then
  echo "✖ Commit message must reference at least one Plane work item (COBUD-<n>):" >&2
  echo "    feat: add codex section (COBUD-6)" >&2
  echo "  Project: https://app.plane.so/apps3k/projects/703acd2a-ef88-4165-8394-34b2cc48a6ab/issues" >&2
  exit 1
fi
